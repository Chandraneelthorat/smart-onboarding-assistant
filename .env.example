# Run API: uv run python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000
# Run frontend: cd frontend && npm run dev
#
# Frontend API base: `npm run dev` / `npm run preview` proxy /api → 127.0.0.1:8000 (frontend/vite.config.ts).
# If you host the built SPA elsewhere without /api proxy, set frontend/.env: VITE_API_BASE_URL=http://127.0.0.1:8000

# PostgreSQL (required for API + MCP)
DATABASE_URL=postgresql://USER@localhost:5432/hrms_db

# Dev/demo: when 1/true, create E001 (lead) + E002 (report) if employees table is empty.
# Run before portal seed so PORTAL_EMP_EMP_ID=E001 is valid. Remove or set 0 in production.
HR_SEED_DEMO_EMPLOYEES=1

# Gmail SMTP (optional; used for manager onboarding notices and other API email tools — not the new hire mailbox)
CB_EMAIL=
CB_EMAIL_PWD=

# OpenRouter — required for POST /api/chat (AI assistant)
OPENROUTER_API_KEY=
# Optional overrides:
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=http://localhost:5173
# OPENROUTER_TITLE=HR-ASSIST

# If set, /api/* requires X-API-Key (same value for HR and Employee clients). Legacy: HR_API_KEY
API_KEY=
# HR_API_KEY=

# Optional: store this employee id as leave approver when the HR portal user has no linked employee_id (audit trail). Approvals work without it.
# HR_APPROVER_EMP_ID=E001

# Comma-separated origins for browser CORS (FastAPI)
HR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
